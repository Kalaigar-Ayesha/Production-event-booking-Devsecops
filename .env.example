# Copy to ".env" in this directory for docker compose (and optional local tooling).
# Never commit a real .env file.

# MongoDB (root user; used for compose init + API connection string)
MONGO_ROOT_USERNAME=eventora_root
MONGO_ROOT_PASSWORD=use-a-long-random-password-without-uri-reserved-chars

# API signing (required for compose; use a long random string in production)
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars

# Optional: outbound email (Gmail app password, etc.)
# EMAIL_USER=
# EMAIL_PASS=

# Optional: Atlas / SRV DNS tuning (see server/server.js)
# DNS_SERVERS=8.8.8.8,1.1.1.1
# USE_SYSTEM_DNS=
